{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*"]
  },
  "routes": [
    {
      "route": "/",
      "redirect": "/",
      "statusCode": 200
    },
    {
      "route": "/portal",
      "rewrite": "/index.html"
    },
    {
      "route": "/portal/*",
      "rewrite": "/index.html"
    },
    {
      "route": "/income",
      "rewrite": "/index.html"
    },
    {
      "route": "/expenses",
      "rewrite": "/index.html"
    },
    {
      "route": "/investment",
      "rewrite": "/index.html"
    }
  ]
}
