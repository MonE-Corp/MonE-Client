{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*"]
  },
  "routes": [
    {
      "route": "/",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/portal/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "redirect": "/",
      "statusCode": 302
    },
    {
      "route": "/logout",
      "redirect": "/",
      "statusCode": 302
    },
    {
      "route": "/.auth/*",
      "rewrite": "/.auth/*"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
